{
  "name": "music-catalog-core",
  "version": "1.0.0",
  "private": true,
  "description": "Backend/API and workers for Media Rosenqvist music catalog",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/audio-processing.worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/audio-processing.worker.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/storage/__tests__/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/s3-request-presigner": "^3.901.0",
    "@supabase/supabase-js": "^2.57.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jose": "^5.10.0",
    "pino": "^9.14.0",
    "zod": "^3.25.76",
    "@azure/storage-blob": "^12.27.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^22.18.11",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
