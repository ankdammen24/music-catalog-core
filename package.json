{
  "name": "music-catalog-core",
  "private": true,
  "version": "0.1.0",
  "description": "Unified backend monorepo for Media Rosenqvist music catalog",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @mrq/api dev",
    "dev:audio-worker": "pnpm --filter @mrq/audio-worker dev",
    "dev:distribution-worker": "pnpm --filter @mrq/distribution-worker dev",
    "dev:radio-sync-worker": "pnpm --filter @mrq/radio-sync-worker dev",
    "dev": "pnpm dev:api"
  }
}
